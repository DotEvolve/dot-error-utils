{
  "name": "@dotevolve/error-utils",
  "version": "1.0.8",
  "description": "Shared error handling utilities with Sentry integration for Node.js and Express services",
  "exports": {
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "default": "./dist/express.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "error-handling",
    "sentry",
    "middleware",
    "express"
  ],
  "author": "DotEvolve",
  "license": "ISC",
  "peerDependencies": {
    "express": "^4.0.0 || ^5.0.0",
    "react": ">=16.14.0",
    "react-dom": ">=16.14.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/pino": "^7.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "express": "^4.22.1",
    "fast-check": "^4.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "dependencies": {
    "@dotevolve/error-utils": "file:",
    "@sentry/node": "^10.40.0",
    "@sentry/profiling-node": "^10.40.0",
    "@sentry/react": "^10.44.0",
    "pino": "^10.3.1"
  }
}
